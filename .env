
# --- Postgres ---
POSTGRES_PASSWORD=1

# --- HMAC подпись для верификационных ссылок ---
# Для генерации:
#   openssl rand -base64 32
HMAC_SIGNATURE=1

# --- SMTP ---
SMTP_HOST=1
SMTP_PORT=1
SMTP_USER=1
SMTP_PASSWORD=1

# --- Домены (без схемы, без слеша на конце) ---
# Используются в ALLOW_ORIGINS, BASE_VERIFY_URL и для Caddy/Nginx
PUBLIC_FRONTEND_DOMAIN=1
PUBLIC_API_DOMAIN=1

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=1
