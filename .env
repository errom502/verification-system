
# --- Postgres ---
POSTGRES_PASSWORD=password

# --- HMAC подпись для верификационных ссылок ---
# Для генерации:
#   openssl rand -base64 32
HMAC_SIGNATURE=signature

# --- SMTP ---
SMTP_HOST=host
SMTP_PORT=port
SMTP_USER=mail
SMTP_PASSWORD=pass

# --- Домены (без схемы, без слеша на конце) ---
# Используются в ALLOW_ORIGINS, BASE_VERIFY_URL и для Caddy/Nginx
PUBLIC_FRONTEND_DOMAIN=domen.com
PUBLIC_API_DOMAIN=domen.com

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=password
