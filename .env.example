# --- Postgres ---
POSTGRES_PASSWORD=change_me_strong_password

# --- HMAC подпись для верификационных ссылок ---
# Сгенерируй новый секрет для прода, не используй dev-значение:
#   openssl rand -base64 32
HMAC_SIGNATURE=change_me_generate_new_secret

# --- SMTP ---
SMTP_HOST=smtp.mail.ru
SMTP_PORT=587
SMTP_USER=your_email@mail.ru
SMTP_PASSWORD=change_me

# --- Домены (без схемы, без слеша на конце) ---
# Используются в ALLOW_ORIGINS, BASE_VERIFY_URL и для Caddy/Nginx
PUBLIC_FRONTEND_DOMAIN=your-domain.com
PUBLIC_API_DOMAIN=api.your-domain.com

# --- Grafana ---
GRAFANA_ADMIN_PASSWORD=change_me_strong_password
